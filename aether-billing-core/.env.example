PORT=5000
STRIPE_PLATFORM_SECRET_KEY=sk_test_your_platform_secret_key
STRIPE_PLATFORM_PUBLIC_KEY=pk_test_your_platform_publishable_key
AETHER_INTERNAL_SECRET=replace_with_a_long_random_shared_secret
STRIPE_CLIENT_ID=ca_your_stripe_connect_client_id
AETHER_ALLOWED_ORIGIN=https://your-wordpress-site.example,https://terminal.aetherframeworks.dev
NODE_BASE_URL=https://billing.aetherframeworks.dev
# Match your Stripe account default (e.g. usd, eur)
STRIPE_DEFAULT_CURRENCY=usd
STRIPE_DEFAULT_COUNTRY=US
# Stripe webhook signing secret — required for installment payment-link completion
# 1. Stripe Dashboard → Developers → Webhooks → Add endpoint
# 2. URL: https://billing.aetherframeworks.dev/api/v1/webhooks/stripe
# 3. Events: payment_intent.succeeded (Connect: events on connected accounts)
# 4. Copy the signing secret (whsec_...) below
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Set to "off" to disable hourly auto-charge scheduler
# AETHER_INSTALLMENT_SCHEDULER=off

# Resend transactional email (optional — omit to disable all Pay in 4 emails)
# Verify your sending domain in Resend before going live.
# RESEND_API_KEY=re_your_api_key
# RESEND_FROM=Aether Pay <payments@aetherframeworks.dev>
